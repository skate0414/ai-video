# Gemini API Key (optional — enables balanced/premium quality tiers)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server port (default: 3220)
PORT=3220

# Data storage directory (default: Tauri APPDATA → OS app data → ./data)
DATA_DIR=

# CORS allowed origins (comma-separated; empty = allow all, dev only)
# Example: http://localhost:5173,http://localhost:3220
ALLOWED_ORIGINS=

# API key for endpoint authentication (optional; empty = no auth)
# When set, all requests must include: Authorization: Bearer <key>
API_KEY=

# Maximum SSE connections (default: 50)
MAX_SSE_CLIENTS=50
