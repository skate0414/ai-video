{
  "name": "ai-video",
  "version": "0.1.0",
  "private": true,
  "description": "AI Video Pipeline — automated video generation with free-tier chat + paid API routing",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node --import tsx src/server.ts",
    "dev:ui": "cd ui && npm run dev",
    "start": "node --import tsx src/server.ts",
    "build": "tsc --noEmit",
    "build:ui": "cd ui && npm run build",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "build:tauri": "npm run build:sidecar && cd ui && npx tauri build",
    "dev:tauri": "cd ui && npx tauri dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && cd ui && npx tsc -b",
    "lint": "tsc --noEmit && cd ui && npx tsc -b"
  },
  "dependencies": {
    "@google/genai": "^1.47.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "playwright": "^1.55.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
