{
  "name": "ai-video",
  "version": "0.1.0",
  "private": true,
  "description": "Multimodal Content Compiler — compiles topic + style reference into production-ready video via 15-pass compilation pipeline",
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/server.ts",
    "dev:ui": "cd ui && npm run dev",
    "dev:electron:ui": "node -e \"const u='http://127.0.0.1:5173';const t=Date.now();(function p(){fetch(u).then(()=>process.exit(0)).catch(()=>Date.now()-t>6e4?process.exit(1):setTimeout(p,300));})();\" && AI_VIDEO_UI_URL=http://127.0.0.1:5173 npm run dev:electron",
    "dev:desktop": "concurrently -k -n UI,DESKTOP -c cyan,green \"npm run dev:ui\" \"npm run dev:electron:ui\"",
    "start": "node --import tsx src/server.ts",
    "start:backend:test": "node src/testing/scripts/start-server.mjs",
    "build": "tsc --noEmit",
    "build:ui": "cd ui && npm run build",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "dev:electron": "cd browser-shell && npm run dev",
    "build:electron": "cd browser-shell && npm run build",
    "package:electron": "npm run build:sidecar && cd browser-shell && npm run package",
    "test": "vitest run",
    "test:backend": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "accept:backend": "node src/testing/scripts/accept-backend.mjs",
    "accept:backend:ci": "node src/testing/scripts/accept-backend.mjs --report-dir artifacts/backend-acceptance",
    "accept:preflight": "node src/testing/scripts/preflight-health-check.mjs --strong",
    "accept:create-project": "node src/testing/scripts/create-new-project.mjs",
    "accept:auto-run": "node src/testing/scripts/auto-run-project.mjs",
    "accept:check-progress": "node src/testing/scripts/check-progress.mjs",
    "accept:check-scenes": "node src/testing/scripts/check-scenes.mjs",
    "accept:recover-video": "node src/testing/scripts/retry-video-gen.mjs",
    "accept:probe-account": "node src/testing/scripts/probe-account.mjs",
    "debug:config": "node src/testing/scripts/check-config.mjs",
    "debug:provider-login": "node src/testing/scripts/check-video-provider-login.mjs",
    "debug:provider-dom": "node src/testing/scripts/inspect-provider-dom.mjs",
    "auth:seedance": "node src/testing/scripts/open-seedance-login.mjs",
    "auth:kling": "node src/testing/scripts/open-kling-login.mjs",
    "pipeline:standalone": "node scripts/run-pipeline.mjs",
    "pipeline:free": "node scripts/run-free-pipeline.mjs",
    "replay": "npx tsx src/cli/replay.ts",
    "typecheck": "tsc --noEmit && cd ui && npx tsc -b",
    "lint": "tsc --noEmit && cd ui && npx tsc -b",
    "lint:deps": "node scripts/lint-dependencies.mjs",
    "lint:deps:diff": "node scripts/lint-dependencies.mjs --check-diff",
    "lint:deps:strict": "node scripts/lint-dependencies.mjs --strict"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "undici": "^7.24.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.55.1",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
