# Gemini API Key (optional — enables balanced/premium quality tiers)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Server port (default: 3220)
PORT=3220

# Data storage directory (default: Electron APPDATA → OS app data → ./data)
DATA_DIR=

# CORS allowed origins (comma-separated; empty = allow all, dev only)
# Example: http://localhost:5173,http://localhost:3220
ALLOWED_ORIGINS=

# API key for endpoint authentication (optional; empty = no auth)
# When set, all requests must include: Authorization: Bearer <key>
API_KEY=

# Maximum SSE connections (default: 50)
MAX_SSE_CLIENTS=50

# HTTP/HTTPS proxy for accessing external AI services (e.g. from mainland China)
# Supports HTTP, HTTPS, and SOCKS5 proxies.
# This applies to both Electron browser tabs AND backend HTTP requests.
# Examples:
#   HTTP_PROXY=http://127.0.0.1:7890
#   HTTPS_PROXY=socks5://127.0.0.1:1080
HTTP_PROXY=
HTTPS_PROXY=
