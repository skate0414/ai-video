# ─────────────────────────────────────────────────────────────
#  AI Video — environment configuration template
#  Copy this file to .env and fill in the values you need.
#  Lines starting with # are comments.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────

# HTTP port the backend listens on (default: 3220)
# PORT=3220

# Root directory for all runtime data (projects, uploads, profiles, …)
# DATA_DIR=./data

# Set to "production" in deployed environments
# NODE_ENV=development

# Bearer token required on all API requests.
# Leave empty to disable authentication (dev mode only!).
# API_KEY=your-secret-token-here

# Comma-separated list of CORS origins.
# Empty = allow all (suitable for dev; restrict in production).
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Set to "1" when the server runs behind a reverse proxy that sets X-Forwarded-For.
# TRUST_PROXY=0


# ── AI Providers ─────────────────────────────────────────────

# Google Gemini API key (enables text, image, video, and TTS via Google API).
# Obtain from: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# AIVideoMaker REST API key (enables text-to-video and image-to-video generation).
# AIVIDEOMAKER_API_KEY=


# ── Pipeline Defaults ─────────────────────────────────────────

# Default provider for text-generation stages ("gemini", "chatgpt", "deepseek", etc.)
# DEFAULT_TEXT_PROVIDER=gemini

# Default provider for image-generation stages
# DEFAULT_IMAGE_PROVIDER=chatgpt

# Number of video candidates generated per scene and scored (min 1, max 5)
# CANDIDATE_COUNT=3

# Persistence backend: "sqlite" (recommended) or "json"
# PROJECT_STORE_BACKEND=sqlite
# GLOBAL_STORE_BACKEND=sqlite


# ── Plugins ───────────────────────────────────────────────────

# Set to "1" to load out-of-tree stage/provider plugins at startup
# ENABLE_PLUGINS=0

# Directory scanned for plugin bundles (default: <DATA_DIR>/plugins)
# PLUGINS_DIR=

# Path to the plugin trust allowlist (default: <DATA_DIR>/trusted-plugins.json)
# PLUGIN_TRUST_FILE=

# Set to "1" to abort startup if any plugin fails to load
# PLUGIN_STRICT=0


# ── Rate Limiting ─────────────────────────────────────────────

# Max requests per window per IP address (default: 120)
# RATE_LIMIT_MAX=120

# Rate-limit window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000

# Max simultaneous SSE client connections (default: 50)
# MAX_SSE_CLIENTS=50


# ── Timeouts (milliseconds) ───────────────────────────────────

# Max time to wait for a single chat-automation response (default: 1200000 = 20 min)
# CHAT_RESPONSE_TIMEOUT_MS=1200000

# Per-selector wait when resolving a SelectorChain (default: 2000)
# SELECTOR_RESOLVE_TIMEOUT_MS=2000

# Pollinations image-fetch timeout per request (default: 45000)
# POLLINATIONS_FETCH_TIMEOUT_MS=45000

# Graceful shutdown forced exit delay (default: 10000)
# SHUTDOWN_FORCE_EXIT_MS=10000


# ── Retry Counts ─────────────────────────────────────────────

# Max retries for AI API calls (Gemini, etc.) (default: 3)
# API_MAX_RETRIES=3

# Max retries for file uploads (default: 3)
# FILE_UPLOAD_MAX_RETRIES=3

# Max attempts for Pollinations image generation (default: 5)
# POLLINATIONS_MAX_ATTEMPTS=5

# Max continuation requests for truncated chat responses (default: 3)
# MAX_CONTINUATIONS=3


# ── Selector Health Monitoring ────────────────────────────────

# How often to probe CSS selectors in ms (default: 300000 = 5 min)
# SELECTOR_HEALTH_CHECK_INTERVAL_MS=300000

# Health score below which an SSE warning is emitted (default: 80)
# SELECTOR_HEALTH_WARN_THRESHOLD=80

# Health score below which auto-detection is triggered (default: 60)
# SELECTOR_HEALTH_REDETECT_THRESHOLD=60


# ── Network Proxy ─────────────────────────────────────────────

# HTTP proxy URL for outbound requests (Pollinations, CDN downloads, etc.)
# HTTP_PROXY=http://proxy.example.com:3128


# ── Playwright / Chromium ─────────────────────────────────────

# Override the Chromium binary path (auto-detected by default).
# Required in Docker if using a system Chromium instead of Playwright's own.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
