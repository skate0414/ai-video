{
  "appId": "com.ai-video-pipeline.browser-shell",
  "productName": "AI Video Pipeline",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../ui/dist",
      "to": "ui-dist",
      "filter": ["**/*"]
    },
    {
      "from": "resources/ai-video-server",
      "to": "ai-video-server"
    },
    {
      "from": "resources/browsers",
      "to": "browsers",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": ["dmg", "zip"]
  },
  "win": {
    "target": ["nsis", "zip"]
  },
  "linux": {
    "target": ["AppImage", "deb"]
  }
}
